{
  email admin@mutante.club
}

api.mutante.club {
  encode gzip
  # CORS handled by Colyseus server via matchMaker.controller.getCorsHeaders
  reverse_proxy server:2567
}

yt.mutante.club {
  encode gzip
  # CORS handled by Go service corsMiddleware
  reverse_proxy youtube-api:8081
}

dream.mutante.club {
  encode gzip
  # CORS handled by Express cors middleware in dream-npc service
  reverse_proxy dream-npc:4000
}

proxy.mutante.club {
  encode gzip

  # Strip iframe-blocking headers so the 3D client can embed external sites
  reverse_proxy https://jmail.world {
    header_up Host jmail.world
    header_down -X-Frame-Options
    header_down -Content-Security-Policy
  }
}
