# Copy to .env on the VPS (do not commit .env)

# Residential proxy for YouTube extraction / streaming.
# Format: http://<username>:<password>@<host>:<port>
PROXY_URL=http://USERNAME:PASSWORD@HOST:PORT

# Optional: Netscape cookies.txt contents for age-restricted videos.
# Paste the entire file contents (keep newlines). Leave empty if not needed.
YOUTUBE_COOKIES=

# Gemini API key for Dream NPC chat (required for dream-npc service)
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=
