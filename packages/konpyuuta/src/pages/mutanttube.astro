---
// packages/konpyuuta/src/pages/mutanttube.astro
// Served at /konpyuuta/mutanttube/
// Bio-Industrial Archive from the Void - Geiger meets Winamp
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MUTANT::TUBE // ARCHIVE</title>
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
    /* ═══════════════════════════════════════════════════════════════
       MUTANT::TUBE - BIO-INDUSTRIAL ARCHIVE
       Aesthetic: Geiger meets Winamp in a corrupted server farm
       ═══════════════════════════════════════════════════════════════ */
    
    :root {
      --void-black: #0a0a0a;
      --rust-orange: #B7410E;
      --rust-dark: #8B4513;
      --slime-green: #9ACD32;
      --slime-dark: #556B2F;
      --bone: #F5F5DC;
      --bone-dim: #C0C0C0;
      --steel: #2F4F4F;
      --steel-light: #4A6464;
      --warning: #FFBF00;
      --blood: #8B0000;
      --panel-bg: #1a1a1a;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body { 
      font-family: 'Chakra Petch', sans-serif;
      font-size: 13px; 
      background: var(--void-black);
      color: var(--bone);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Organic pulsing background pattern */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: 
        radial-gradient(ellipse at 20% 80%, rgba(183, 65, 14, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 20%, rgba(154, 205, 50, 0.05) 0%, transparent 50%),
        repeating-linear-gradient(90deg, rgba(139, 69, 19, 0.03) 0px, rgba(139, 69, 19, 0.03) 1px, transparent 1px, transparent 60px);
      pointer-events: none;
      z-index: -1;
      animation: organic-breathe 12s ease-in-out infinite;
    }

    @keyframes organic-breathe {
      0%, 100% { opacity: 0.8; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.01); }
    }

    /* ═══════════════════════════════════════════════════════════════
       LOADING ANIMATION - In Content Area
       ═══════════════════════════════════════════════════════════════ */
    
    .loading-container {
      text-align: center;
      padding: 60px 40px;
      background: var(--panel-bg);
      border: 2px solid var(--rust-orange);
      box-shadow: 
        0 0 40px rgba(183, 65, 14, 0.2),
        inset 0 0 60px rgba(0,0,0,0.5);
      position: relative;
      margin: 20px 0;
    }

    .loading-container::before,
    .loading-container::after {
      content: '◉';
      position: absolute;
      color: var(--steel);
      font-size: 12px;
    }
    .loading-container::before { top: 8px; left: 8px; }
    .loading-container::after { bottom: 8px; right: 8px; }

    .loading-skull {
      font-size: 48px;
      margin-bottom: 16px;
      animation: skull-pulse 1.2s ease-in-out infinite;
      text-shadow: 0 0 20px rgba(183, 65, 14, 0.6);
    }

    @keyframes skull-pulse {
      0%, 100% { transform: scale(1); filter: brightness(1); }
      50% { transform: scale(1.08); filter: brightness(1.3); }
    }

    .loading-text {
      font-family: 'Share Tech Mono', monospace;
      font-size: 14px;
      color: var(--slime-green);
      text-transform: uppercase;
      letter-spacing: 3px;
      margin-bottom: 20px;
    }

    .loading-status {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--bone-dim);
      letter-spacing: 2px;
      min-height: 20px;
      animation: status-flicker 0.5s infinite;
    }

    @keyframes status-flicker {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }

    /* Progress bar */
    .loading-progress {
      width: 250px;
      height: 3px;
      background: var(--steel);
      margin: 16px auto;
      position: relative;
      overflow: hidden;
    }

    .loading-progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--slime-green), var(--rust-orange));
      width: 0%;
      animation: progress-fill 1.5s ease-out forwards;
      box-shadow: 0 0 8px var(--slime-green);
    }

    @keyframes progress-fill {
      0% { width: 0%; }
      100% { width: 100%; }
    }

    /* Matrix rain effect */
    .matrix-rain {
      position: absolute;
      inset: 0;
      overflow: hidden;
      opacity: 0.08;
      pointer-events: none;
    }

    .matrix-char {
      position: absolute;
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      color: var(--slime-green);
      animation: matrix-fall linear infinite;
    }

    @keyframes matrix-fall {
      0% { transform: translateY(-100%); opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { transform: translateY(100%); opacity: 0; }
    }

    /* ═══════════════════════════════════════════════════════════════
       HEADER - Industrial Control Panel
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-header { 
      background: linear-gradient(180deg, #2a2a2a 0%, var(--panel-bg) 100%);
      border-bottom: 3px solid var(--rust-orange);
      padding: 8px 16px;
      display: flex;
      align-items: center;
      gap: 20px;
      box-shadow: 
        0 4px 20px rgba(183, 65, 14, 0.3),
        inset 0 1px 0 rgba(255,255,255,0.1);
      position: relative;
    }

    #mt-header::before,
    #mt-header::after {
      content: '◉';
      position: absolute;
      color: var(--steel);
      font-size: 10px;
      top: 4px;
    }
    #mt-header::before { left: 8px; }
    #mt-header::after { right: 8px; }

    .logo { 
      font-family: 'Share Tech Mono', monospace;
      font-size: 24px; 
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--bone);
      text-shadow: 
        0 0 10px rgba(183, 65, 14, 0.5),
        2px 2px 0 var(--blood);
      position: relative;
      animation: logo-flicker 8s infinite;
    }

    .logo::after {
      content: '::ARCHIVE';
      color: var(--rust-orange);
      font-size: 12px;
      position: absolute;
      bottom: -4px;
      right: 0;
      letter-spacing: 1px;
    }

    @keyframes logo-flicker {
      0%, 90%, 100% { opacity: 1; }
      91% { opacity: 0.8; }
      92% { opacity: 1; }
      93% { opacity: 0.7; }
      94% { opacity: 1; }
    }

    .header-status {
      display: flex;
      gap: 20px;
      margin-left: auto;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--slime-green);
    }

    .status-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .status-indicator {
      width: 8px;
      height: 8px;
      background: var(--slime-green);
      border-radius: 50%;
      animation: status-pulse 2s infinite;
      box-shadow: 0 0 8px var(--slime-green);
    }

    @keyframes status-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    #mt-search-form { 
      display: flex; 
      gap: 8px; 
      flex: 1; 
      max-width: 400px;
      position: relative;
    }

    #mt-search-form::before {
      content: '>';
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--rust-orange);
      font-family: 'Share Tech Mono', monospace;
      font-size: 14px;
      z-index: 1;
    }

    #mt-search-input { 
      flex: 1; 
      padding: 8px 12px 8px 28px;
      background: #0f0f0f;
      border: 1px solid var(--steel);
      color: var(--bone);
      font-family: 'Share Tech Mono', monospace;
      font-size: 13px;
      outline: none;
      transition: all 0.3s;
    }

    #mt-search-input:focus {
      border-color: var(--rust-orange);
      box-shadow: 
        0 0 10px rgba(183, 65, 14, 0.3),
        inset 0 0 20px rgba(183, 65, 14, 0.05);
    }

    #mt-search-btn { 
      padding: 8px 18px;
      background: linear-gradient(180deg, var(--rust-dark) 0%, var(--rust-orange) 100%);
      border: 1px solid var(--rust-orange);
      color: var(--bone);
      cursor: pointer;
      font-family: 'Chakra Petch', sans-serif;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    #mt-search-btn:hover { 
      background: linear-gradient(180deg, var(--rust-orange) 0%, var(--rust-dark) 100%);
      box-shadow: 0 0 15px rgba(183, 65, 14, 0.5);
    }

    #mt-search-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s;
    }

    #mt-search-btn:hover::before {
      left: 100%;
    }

    .btn-skull {
      font-size: 14px;
    }

    /* ═══════════════════════════════════════════════════════════════
       NAVIGATION TABS
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-tabs { 
      background: var(--panel-bg);
      border-bottom: 2px solid var(--steel);
      padding: 0 16px;
      display: flex;
      gap: 4px;
    }

    .mt-tab { 
      padding: 10px 20px;
      cursor: pointer;
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      background: transparent;
      border: none;
      border-bottom: 3px solid transparent;
      color: var(--bone-dim);
      position: relative;
      transition: all 0.3s;
    }

    .mt-tab:hover { 
      color: var(--bone);
      background: rgba(183, 65, 14, 0.1);
    }

    .mt-tab.active { 
      color: var(--rust-orange);
      border-bottom-color: var(--rust-orange);
      background: linear-gradient(180deg, transparent 0%, rgba(183, 65, 14, 0.1) 100%);
      text-shadow: 0 0 10px rgba(183, 65, 14, 0.5);
    }

    .mt-tab.active::before {
      content: '◆';
      position: absolute;
      left: 6px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 8px;
      animation: tab-pulse 2s infinite;
    }

    @keyframes tab-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    /* ═══════════════════════════════════════════════════════════════
       MAIN LAYOUT
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-main { 
      display: flex;
      min-height: calc(100vh - 130px);
      padding-bottom: 60px;
    }

    /* ═══════════════════════════════════════════════════════════════
       SIDEBAR - System Directories
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-sidebar { 
      width: 200px;
      background: linear-gradient(180deg, var(--panel-bg) 0%, #141414 100%);
      padding: 16px;
      border-right: 2px solid var(--steel);
      flex-shrink: 0;
      transition: all 0.3s;
    }

    #mt-sidebar.hidden {
      width: 0;
      padding: 0;
      border: none;
      overflow: hidden;
      opacity: 0;
    }

    #mt-sidebar h3 { 
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--slime-green);
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--steel);
    }

    .directory-item {
      padding: 8px 10px;
      margin-bottom: 4px;
      cursor: pointer;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--bone-dim);
      border-left: 2px solid transparent;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .directory-item::before {
      content: '[ ]';
      color: var(--steel);
    }

    .directory-item:hover {
      color: var(--bone);
      background: rgba(139, 69, 19, 0.2);
      border-left-color: var(--rust-orange);
    }

    .directory-item:hover::before {
      content: '[■]';
      color: var(--rust-orange);
    }

    .directory-item.active {
      color: var(--slime-green);
      border-left-color: var(--slime-green);
      background: rgba(154, 205, 50, 0.1);
    }

    .directory-item.active::before {
      content: '[■]';
      color: var(--slime-green);
    }

    /* ═══════════════════════════════════════════════════════════════
       CONTENT AREA
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-content { 
      flex: 1;
      padding: 20px;
      background: rgba(10, 10, 10, 0.5);
    }

    .section-title {
      font-family: 'Share Tech Mono', monospace;
      font-size: 14px;
      color: var(--slime-green);
      text-transform: uppercase;
      letter-spacing: 3px;
      margin-bottom: 20px;
      padding: 10px 16px;
      background: linear-gradient(90deg, rgba(154, 205, 50, 0.1) 0%, transparent 100%);
      border-left: 4px solid var(--slime-green);
      position: relative;
    }

    .section-title::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, var(--slime-green), transparent);
    }

    /* ═══════════════════════════════════════════════════════════════
       VIDEO GRID - Masonry with Corruption Effects
       ═══════════════════════════════════════════════════════════════ */
    
    .mt-masonry {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 24px;
    }

    .mt-video-card { 
      cursor: pointer;
      background: var(--panel-bg);
      border: 1px solid var(--steel);
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }

    .mt-video-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border: 1px solid transparent;
      transition: border-color 0.3s;
      pointer-events: none;
      z-index: 2;
    }

    .mt-video-card:hover {
      transform: translateY(-4px);
      border-color: var(--rust-orange);
      box-shadow: 
        0 10px 40px rgba(0,0,0,0.5),
        0 0 20px rgba(183, 65, 14, 0.2);
    }

    .mt-video-card:hover::before {
      border-color: var(--rust-orange);
    }

    .mt-thumb-container {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      overflow: hidden;
      background: #000;
    }

    .mt-thumb { 
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: all 0.4s;
      filter: contrast(1.1) saturate(0.9);
    }

    .mt-thumb-container::after {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.1) 2px,
        rgba(0,0,0,0.1) 4px
      );
      pointer-events: none;
      animation: scanline-shift 10s linear infinite;
      opacity: 0.6;
    }

    @keyframes scanline-shift {
      0% { background-position: 0 0; }
      100% { background-position: 0 100px; }
    }

    .mt-video-card:hover .mt-thumb {
      filter: contrast(1.2) saturate(1.1);
      animation: chromatic-shift 0.3s ease-out;
    }

    @keyframes chromatic-shift {
      0% { 
        filter: contrast(1.2) saturate(1.1) drop-shadow(-2px 0 0 rgba(255,0,0,0.3)) drop-shadow(2px 0 0 rgba(0,255,255,0.3));
      }
      100% { 
        filter: contrast(1.2) saturate(1.1);
      }
    }

    .mt-thumb-container::before {
      content: '▶';
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      color: var(--bone);
      background: rgba(0,0,0,0.4);
      opacity: 0;
      transition: all 0.3s;
      z-index: 1;
      text-shadow: 0 0 20px rgba(0,0,0,0.8);
    }

    .mt-video-card:hover .mt-thumb-container::before {
      opacity: 1;
    }

    .mt-thumb-placeholder { 
      width: 100%;
      aspect-ratio: 16/9;
      background: 
        repeating-linear-gradient(45deg, #1a1a1a 0px, #1a1a1a 10px, #222 10px, #222 20px),
        linear-gradient(180deg, var(--rust-dark) 0%, var(--blood) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--bone);
      font-family: 'Share Tech Mono', monospace;
      font-size: 32px;
    }

    .mt-video-info {
      padding: 12px;
    }

    .mt-video-title { 
      font-size: 13px;
      font-weight: 600;
      color: var(--bone);
      line-height: 1.4;
      margin-bottom: 6px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      transition: color 0.2s;
    }

    .mt-video-card:hover .mt-video-title {
      color: var(--rust-orange);
    }

    .mt-video-title.glitch {
      animation: text-glitch 0.3s ease-out;
    }

    @keyframes text-glitch {
      0%, 100% { transform: translate(0); }
      20% { transform: translate(-2px, 1px); }
      40% { transform: translate(2px, -1px); }
      60% { transform: translate(-1px, 2px); }
      80% { transform: translate(1px, -2px); }
    }

    .mt-video-meta { 
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: var(--steel);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .mt-video-meta span {
      color: var(--slime-green);
    }

    /* ═══════════════════════════════════════════════════════════════
       WATCH VIEW - EPIC & WEIRD
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-watch { 
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      margin-bottom: 20px;
      background: transparent;
      border: 1px solid var(--steel);
      color: var(--bone-dim);
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .back-btn:hover {
      border-color: var(--rust-orange);
      color: var(--rust-orange);
      background: rgba(183, 65, 14, 0.1);
    }

    #mt-watch-frame-container {
      position: relative;
      background: #000;
      border: 3px solid var(--rust-orange);
      box-shadow: 
        0 0 60px rgba(183, 65, 14, 0.3),
        inset 0 0 100px rgba(0,0,0,0.5);
      padding: 20px;
    }

    /* Corner decorations */
    .corner-decoration {
      position: absolute;
      width: 40px;
      height: 40px;
      border: 2px solid var(--slime-green);
      z-index: 10;
    }

    .corner-tl { top: -3px; left: -3px; border-right: none; border-bottom: none; }
    .corner-tr { top: -3px; right: -3px; border-left: none; border-bottom: none; }
    .corner-bl { bottom: -3px; left: -3px; border-right: none; border-top: none; }
    .corner-br { bottom: -3px; right: -3px; border-left: none; border-top: none; }

    .corner-decoration::before {
      content: '◉';
      position: absolute;
      font-size: 8px;
      color: var(--rust-orange);
    }

    .corner-tl::before { top: 2px; left: 2px; }
    .corner-tr::before { top: 2px; right: 2px; }
    .corner-bl::before { bottom: 2px; left: 2px; }
    .corner-br::before { bottom: 2px; right: 2px; }

    /* Scanlines overlay on video */
    .video-scanlines {
      position: absolute;
      inset: 20px;
      pointer-events: none;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.15) 2px,
        rgba(0,0,0,0.15) 4px
      );
      z-index: 5;
      opacity: 0.6;
    }

    /* Warning labels */
    .video-warning {
      position: absolute;
      top: 10px;
      right: 10px;
      background: var(--blood);
      color: var(--bone);
      padding: 4px 12px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 2px;
      z-index: 10;
      animation: warning-blink 1s infinite;
    }

    @keyframes warning-blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0.5; }
    }

    #mt-watch-frame { 
      width: 100%;
      aspect-ratio: 16/9;
      border: none;
      background: #000;
      display: block;
    }

    /* Video info panel */
    #mt-watch-info {
      margin-top: 20px;
      padding: 24px;
      background: var(--panel-bg);
      border: 2px solid var(--steel);
      position: relative;
    }

    #mt-watch-info::before {
      content: '◈ SIGNAL ACQUIRED ◈';
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--void-black);
      padding: 0 20px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--slime-green);
      letter-spacing: 3px;
    }

    #mt-watch-title { 
      font-size: 22px;
      font-weight: 700;
      color: var(--bone);
      margin-bottom: 16px;
      font-family: 'Share Tech Mono', monospace;
      text-shadow: 0 0 10px rgba(183, 65, 14, 0.3);
    }

    /* Weird stats */
    .video-stats {
      display: flex;
      gap: 24px;
      margin-bottom: 20px;
      padding: 16px;
      background: rgba(0,0,0,0.3);
      border-left: 3px solid var(--rust-orange);
    }

    .stat-item {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
    }

    .stat-label {
      color: var(--steel);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 4px;
    }

    .stat-value {
      color: var(--slime-green);
      font-size: 14px;
      font-weight: 600;
    }

    #mt-watch-actions { 
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .action-btn {
      padding: 12px 24px;
      background: linear-gradient(180deg, var(--steel) 0%, var(--steel-light) 100%);
      border: 2px solid var(--steel);
      color: var(--bone);
      font-family: 'Chakra Petch', sans-serif;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .action-btn:hover {
      background: linear-gradient(180deg, var(--rust-dark) 0%, var(--rust-orange) 100%);
      border-color: var(--rust-orange);
      box-shadow: 0 0 20px rgba(183, 65, 14, 0.4);
      transform: translateY(-2px);
    }

    .action-btn.primary {
      background: linear-gradient(180deg, var(--slime-dark) 0%, var(--slime-green) 100%);
      border-color: var(--slime-green);
      color: var(--void-black);
    }

    .action-btn.primary:hover {
      box-shadow: 0 0 20px rgba(154, 205, 50, 0.4);
    }

    /* Glitchy decorations */
    .glitch-decoration {
      position: absolute;
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: var(--blood);
      opacity: 0.3;
      pointer-events: none;
      animation: glitch-float 3s ease-in-out infinite;
    }

    @keyframes glitch-float {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      25% { transform: translate(5px, -5px) rotate(2deg); }
      50% { transform: translate(-3px, 3px) rotate(-1deg); }
      75% { transform: translate(4px, 2px) rotate(1deg); }
    }

    /* ═══════════════════════════════════════════════════════════════
       PLAYLIST STYLES
       ═══════════════════════════════════════════════════════════════ */
    
    .mt-playlist-item { 
      padding: 14px 16px;
      margin-bottom: 8px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--panel-bg);
      border: 1px solid var(--steel);
      border-left: 3px solid var(--steel);
      transition: all 0.3s;
    }

    .mt-playlist-item:hover { 
      background: rgba(139, 69, 19, 0.1);
      border-color: var(--rust-orange);
      border-left-color: var(--rust-orange);
      transform: translateX(4px);
    }

    .mt-playlist-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .mt-playlist-name { 
      font-weight: 600;
      font-size: 14px;
      color: var(--bone);
      font-family: 'Share Tech Mono', monospace;
    }

    .mt-playlist-count { 
      font-size: 10px;
      color: var(--slime-green);
      font-family: 'Share Tech Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .mt-btn-delete { 
      color: var(--blood);
      font-size: 11px;
      cursor: pointer;
      background: transparent;
      border: 1px solid var(--blood);
      padding: 6px 12px;
      font-family: 'Share Tech Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.2s;
    }

    .mt-btn-delete:hover {
      background: var(--blood);
      color: var(--bone);
    }

    .mt-btn-new { 
      padding: 12px 24px;
      background: linear-gradient(180deg, var(--slime-dark) 0%, var(--slime-green) 100%);
      border: 1px solid var(--slime-green);
      color: var(--void-black);
      font-family: 'Chakra Petch', sans-serif;
      font-weight: 700;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 2px;
      cursor: pointer;
      margin-bottom: 20px;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .mt-btn-new:hover {
      box-shadow: 0 0 20px rgba(154, 205, 50, 0.4);
      transform: translateY(-2px);
    }

    .mt-track-item { 
      padding: 12px 16px;
      border-bottom: 1px solid var(--steel);
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      background: rgba(20, 20, 20, 0.5);
      transition: all 0.2s;
    }

    .mt-track-item:hover { 
      background: rgba(183, 65, 14, 0.1);
      border-left: 3px solid var(--rust-orange);
      margin-left: -3px;
      padding-left: 19px;
    }

    .mt-track-title { 
      font-size: 13px;
      color: var(--bone-dim);
      font-family: 'Share Tech Mono', monospace;
    }

    .mt-track-item:hover .mt-track-title {
      color: var(--bone);
    }

    .mt-btn-back { 
      padding: 8px 16px;
      font-size: 12px;
      cursor: pointer;
      border: 1px solid var(--steel);
      background: transparent;
      color: var(--bone-dim);
      font-family: 'Share Tech Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 16px;
      transition: all 0.2s;
    }

    .mt-btn-back:hover { 
      border-color: var(--rust-orange);
      color: var(--rust-orange);
      background: rgba(183, 65, 14, 0.1);
    }

    /* ═══════════════════════════════════════════════════════════════
       PAGINATION
       ═══════════════════════════════════════════════════════════════ */
    
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-top: 32px;
      padding: 20px;
    }

    .pagination-btn {
      padding: 10px 18px;
      background: transparent;
      border: 1px solid var(--steel);
      color: var(--bone-dim);
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .pagination-btn:hover:not(:disabled) {
      border-color: var(--rust-orange);
      color: var(--rust-orange);
      background: rgba(183, 65, 14, 0.1);
    }

    .pagination-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .pagination-info {
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      color: var(--slime-green);
      padding: 0 16px;
    }

    .pagination-info span {
      color: var(--bone);
    }

    /* ═══════════════════════════════════════════════════════════════
       STATUS BAR
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-status-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--panel-bg);
      border-top: 2px solid var(--steel);
      padding: 8px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      z-index: 100;
    }

    .status-text {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--slime-green);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .equalizer {
      display: flex;
      align-items: end;
      gap: 2px;
      height: 24px;
    }

    .eq-bar {
      width: 4px;
      background: linear-gradient(180deg, var(--slime-green) 0%, var(--rust-orange) 100%);
      animation: eq-bounce 0.5s ease-in-out infinite alternate;
    }

    .eq-bar:nth-child(1) { height: 40%; animation-delay: 0s; }
    .eq-bar:nth-child(2) { height: 70%; animation-delay: 0.1s; }
    .eq-bar:nth-child(3) { height: 50%; animation-delay: 0.2s; }
    .eq-bar:nth-child(4) { height: 80%; animation-delay: 0.05s; }
    .eq-bar:nth-child(5) { height: 60%; animation-delay: 0.15s; }
    .eq-bar:nth-child(6) { height: 90%; animation-delay: 0.08s; }
    .eq-bar:nth-child(7) { height: 45%; animation-delay: 0.12s; }
    .eq-bar:nth-child(8) { height: 75%; animation-delay: 0.03s; }
    .eq-bar:nth-child(9) { height: 55%; animation-delay: 0.18s; }
    .eq-bar:nth-child(10) { height: 85%; animation-delay: 0.07s; }

    @keyframes eq-bounce {
      0% { transform: scaleY(0.3); opacity: 0.6; }
      100% { transform: scaleY(1); opacity: 1; }
    }

    /* ═══════════════════════════════════════════════════════════════
       STATUS MESSAGES
       ═══════════════════════════════════════════════════════════════ */
    
    #mt-status { 
      color: var(--bone-dim);
      font-size: 14px;
      padding: 40px;
      text-align: center;
      font-family: 'Share Tech Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    #mt-status::before {
      content: '⟳ ';
      animation: loading-spin 1s linear infinite;
      display: inline-block;
    }

    @keyframes loading-spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    #mt-error { 
      color: var(--blood);
      font-size: 14px;
      padding: 40px;
      text-align: center;
      font-family: 'Share Tech Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 2px;
      border: 1px solid var(--blood);
      background: rgba(139, 0, 0, 0.1);
    }

    #mt-error::before {
      content: '⚠ ';
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--steel);
      font-family: 'Share Tech Mono', monospace;
    }

    .empty-state::before {
      content: '[ EMPTY ]';
      display: block;
      font-size: 24px;
      margin-bottom: 16px;
      color: var(--steel-light);
    }

    /* ═══════════════════════════════════════════════════════════════
       SCROLLBAR
       ═══════════════════════════════════════════════════════════════ */
    
    ::-webkit-scrollbar {
      width: 10px;
    }

    ::-webkit-scrollbar-track {
      background: var(--void-black);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--steel);
      border: 2px solid var(--void-black);
    }

    ::-webkit-scrollbar-thumb:hover {
      background: var(--rust-orange);
    }
  </style>
</head>
<body>
  <div id="mt-header">
    <div class="logo">MUTANT</div>
    <form id="mt-search-form" onsubmit="mtSearch(event)">
      <input id="mt-search-input" type="text" placeholder="SEARCH ARCHIVES..." autocomplete="off" />
      <button type="submit" id="mt-search-btn">
        <span class="btn-skull">💀</span>
        <span>SEARCH</span>
      </button>
    </form>
    <div class="header-status">
      <div class="status-item">
        <div class="status-indicator"></div>
        <span>SYSTEM: ONLINE</span>
      </div>
      <div class="status-item">
        <span>INTEGRITY: 87%</span>
      </div>
    </div>
  </div>

  <div id="mt-tabs">
    <div class="mt-tab active" id="tab-home" onclick="mtShowView('homepage')">Home</div>
    <div class="mt-tab" id="tab-playlists" onclick="mtShowView('playlists')">Playlists</div>
  </div>

  <div id="mt-main">
    <div id="mt-sidebar">
      <h3>Directories</h3>
      <div class="directory-item" data-category="home-videos" onclick="mtFilterByCategory('home-videos', 'Home Videos')">Home Videos</div>
      <div class="directory-item" data-category="music" onclick="mtFilterByCategory('music', 'Music')">Music</div>
      <div class="directory-item" data-category="comedy" onclick="mtFilterByCategory('comedy', 'Comedy')">Comedy</div>
      <div class="directory-item" data-category="tv-shows" onclick="mtFilterByCategory('tv-shows', 'TV Shows')">TV Shows</div>
      <div class="directory-item" data-category="weird" onclick="mtFilterByCategory('weird', 'Weird & Strange')">Weird & Strange</div>
      <div class="directory-item" data-category="vintage" onclick="mtFilterByCategory('vintage', 'Vintage')">Vintage</div>
      <div class="directory-item" data-category="public-access" onclick="mtFilterByCategory('public-access', 'Public Access')">Public Access</div>
      <div class="directory-item" data-category="corrupted" onclick="mtFilterByCategory('corrupted', 'Corrupted Data')">Corrupted Data</div>
    </div>
    <div id="mt-content">
      <div id="mt-status">INITIALIZING ARCHIVE...</div>
    </div>
  </div>

  <div id="mt-status-bar">
    <div class="status-text" id="mt-status-text">Ready</div>
    <div class="equalizer">
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
      <div class="eq-bar"></div>
    </div>
  </div>

  <script is:inline>
    // ═══════════════════════════════════════════════════════════════
    // MUTANT::TUBE - Core Functions
    // ═══════════════════════════════════════════════════════════════

    var ITEMS_PER_PAGE = 12;

    function getSession() {
      return window.parent.nakamaSession || null;
    }

    function nakamaBase(session) {
      return (session.ssl ? 'https' : 'http') + '://' + session.host + ':' + session.port;
    }

    function getUserId(session) {
      try {
        return JSON.parse(atob(session.token.split('.')[1])).sub;
      } catch(e) {
        return null;
      }
    }

    async function rpc(id, payload) {
      const session = getSession();
      if (!session) throw new Error('No session');
      const res = await fetch(nakamaBase(session) + '/v2/rpc/' + id, {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + session.token,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('RPC ' + id + ' failed: ' + res.status);
      const json = await res.json();
      return JSON.parse(json.payload);
    }

    async function ytSearch(q, limit) {
      const session = getSession();
      if (!session) throw new Error('No session');
      const res = await fetch(session.youtubeApiUrl + '/search?q=' + encodeURIComponent(q) + '&limit=' + (limit || 20));
      if (!res.ok) throw new Error('YouTube search failed: ' + res.status);
      return res.json();
    }

    function escAttr(s) {
      return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;');
    }

    function setStatusText(text) {
      document.getElementById('mt-status-text').textContent = text;
    }

    // State
    var currentView = 'homepage';
    var currentVideo = null;
    var currentPlaylist = null;
    var playlistMap = {};
    var currentSearchQuery = '';
    var currentCategory = null;
    var currentPage = 1;
    var totalResults = [];
    var totalPages = 1;

    var WEIRD_TERMS = [
      '1996 local TV commercial',
      'forgotten VHS home video 1993',
      'obscure public access show 1998',
      'weird internet video 2002',
      'rare 90s cartoon pilot',
      'lost TV special 1995',
      'public access cable 1997',
      'strange music video 1994',
    ];

    var CATEGORY_TERMS = {
      'home-videos': ['home video 1990', 'family VHS 1995', 'amateur recording 1998'],
      'music': ['music video 1994', 'live performance 1996', 'MTV underground'],
      'comedy': ['stand up 1995', 'comedy sketch 1990s', 'funny home video'],
      'tv-shows': ['90s TV show', 'pilot episode rare', 'public access TV'],
      'weird': ['weird video', 'strange footage', 'bizarre clip'],
      'vintage': ['vintage footage', 'old film', 'retro video'],
      'public-access': ['public access', 'cable access', 'community TV'],
      'corrupted': ['corrupted video', 'glitch footage', 'damaged VHS']
    };

    function pickRandom(arr, n) {
      var copy = arr.slice();
      var result = [];
      for (var i = 0; i < n && copy.length > 0; i++) {
        var idx = Math.floor(Math.random() * copy.length);
        result.push(copy.splice(idx, 1)[0]);
      }
      return result;
    }

    function triggerGlitch(element) {
      element.classList.add('glitch');
      setTimeout(function() {
        element.classList.remove('glitch');
      }, 300);
    }

    function setContent(html) {
      document.getElementById('mt-content').innerHTML = html;
    }

    function setStatus(msg) {
      setContent('<div id="mt-status">' + msg + '</div>');
    }

    function setError(msg) {
      setContent('<div id="mt-error">Error: ' + msg + '</div>');
      setStatusText('ERROR DETECTED');
    }

    function setTabActive(tab) {
      document.querySelectorAll('.mt-tab').forEach(function(el) { el.classList.remove('active'); });
      var el = document.getElementById('tab-' + tab);
      if (el) el.classList.add('active');
    }

    function setActiveDirectory(category) {
      document.querySelectorAll('.directory-item').forEach(function(el) { el.classList.remove('active'); });
      if (category) {
        var el = document.querySelector('.directory-item[data-category="' + category + '"]');
        if (el) el.classList.add('active');
      }
    }

    function toggleSidebar(show) {
      var sidebar = document.getElementById('mt-sidebar');
      if (show) {
        sidebar.classList.remove('hidden');
      } else {
        sidebar.classList.add('hidden');
      }
    }

    function videoCardHTML(video, index) {
      var id = video.videoId || video.id || '';
      var title = (video.title || 'Unknown').replace(/</g, '&lt;');
      var thumb = video.thumbnail || '';
      var views = video.viewCount != null ? Number(video.viewCount).toLocaleString() : '???';
      var timestamp = video.publishedAt ? formatTimeAgo(video.publishedAt) : 'UNKNOWN DATE';
      var thumbHTML = thumb
        ? '<img class="mt-thumb" src="' + thumb + '" alt="" loading="lazy" />'
        : '<div class="mt-thumb-placeholder">▶</div>';
      
      return '<div class="mt-video-card" data-vid-id="' + escAttr(id) + '" data-vid-title="' + escAttr(title) + '" onclick="mtWatchVideoCard(this)">'
        + '<div class="mt-thumb-container">' + thumbHTML + '</div>'
        + '<div class="mt-video-info">'
        + '<div class="mt-video-title" data-index="' + index + '">' + title + '</div>'
        + '<div class="mt-video-meta"><span>' + views + '</span> VIEWS // ' + timestamp + '</div>'
        + '</div></div>';
    }

    function formatTimeAgo(dateString) {
      try {
        var date = new Date(dateString);
        var now = new Date();
        var diff = Math.floor((now - date) / 1000);
        
        if (diff < 60) return diff + ' SECONDS AGO';
        if (diff < 3600) return Math.floor(diff / 60) + ' MINUTES AGO';
        if (diff < 86400) return Math.floor(diff / 3600) + ' HOURS AGO';
        if (diff < 2592000) return Math.floor(diff / 86400) + ' DAYS AGO';
        if (diff < 31536000) return Math.floor(diff / 2592000) + ' MONTHS AGO';
        return Math.floor(diff / 31536000) + ' YEARS AGO';
      } catch(e) {
        return 'UNKNOWN DATE';
      }
    }

    function mtWatchVideoCard(el) {
      mtWatchVideo({ id: el.dataset.vidId, title: el.dataset.vidTitle });
    }

    function mtWatchTrack(el) {
      mtWatchVideo({ id: el.dataset.vidId, title: el.dataset.vidTitle });
    }

    function mtOpenPlaylistById(id) {
      var pl = playlistMap[id];
      if (pl) mtOpenPlaylist(pl);
    }

    // Pagination HTML
    function paginationHTML(currentPage, totalPages, resultsCount) {
      if (totalPages <= 1) return '';
      
      return '<div class="pagination">'
        + '<button class="pagination-btn" onclick="mtGoToPage(' + (currentPage - 1) + ')" ' + (currentPage <= 1 ? 'disabled' : '') + '>< PREV</button>'
        + '<div class="pagination-info">PAGE <span>' + currentPage + '</span> / <span>' + totalPages + '</span> // ' + resultsCount + ' FRAGMENTS</div>'
        + '<button class="pagination-btn" onclick="mtGoToPage(' + (currentPage + 1) + ')" ' + (currentPage >= totalPages ? 'disabled' : '') + '>NEXT ></button>'
        + '</div>';
    }

    function renderResultsPage(items, pageNum) {
      currentPage = pageNum;
      totalPages = Math.ceil(items.length / ITEMS_PER_PAGE);
      
      var start = (pageNum - 1) * ITEMS_PER_PAGE;
      var end = start + ITEMS_PER_PAGE;
      var pageItems = items.slice(start, end);
      
      var html = '<div class="mt-masonry">';
      pageItems.forEach(function(v, i) { html += videoCardHTML(v, start + i); });
      html += '</div>';
      html += paginationHTML(pageNum, totalPages, items.length);
      
      return html;
    }

    function mtGoToPage(pageNum) {
      if (pageNum < 1 || pageNum > totalPages) return;
      
      var titleText = '';
      if (currentSearchQuery) {
        titleText = 'QUERY RESULTS: ' + totalResults.length + ' MATCHES';
      } else if (currentCategory) {
        var activeEl = document.querySelector('.directory-item.active');
        var catName = activeEl ? activeEl.textContent : 'ARCHIVE';
        titleText = '⚠ ' + catName.toUpperCase() + ' ARCHIVE ⚠';
      } else {
        titleText = '⚠ FRAGMENTED SIGNALS DETECTED ⚠';
      }
      
      var html = '<div class="section-title">' + titleText + '</div>';
      html += renderResultsPage(totalResults, pageNum);
      setContent(html);
      
      // Scroll to top of content
      document.getElementById('mt-content').scrollIntoView({ behavior: 'smooth', block: 'start' });
      
      // Random glitch effect
      setTimeout(function() {
        document.querySelectorAll('.mt-video-title').forEach(function(el) {
          if (Math.random() > 0.7) {
            setTimeout(function() { triggerGlitch(el); }, Math.random() * 1000);
          }
        });
      }, 300);
    }

    // Loading animation in content area
    function showLoadingAnimation() {
      var messages = [
        'BYPASSING SECURITY...',
        'DECRYPTING DATABASE...',
        'EXTRACTING FRAGMENTS...',
        'COMPILING RESULTS...'
      ];
      
      var matrixChars = '';
      var chars = '01アイウエオカキクケコ';
      for (var i = 0; i < 20; i++) {
        matrixChars += '<div class="matrix-char" style="left:' + (Math.random() * 100) + '%;animation-duration:' + (Math.random() * 2 + 2) + 's;animation-delay:' + Math.random() + 's">' + chars[Math.floor(Math.random() * chars.length)] + '</div>';
      }
      
      var html = '<div class="loading-container">'
        + '<div class="matrix-rain">' + matrixChars + '</div>'
        + '<div class="loading-skull">💀</div>'
        + '<div class="loading-text">DECRYPTING ARCHIVE</div>'
        + '<div class="loading-progress"><div class="loading-progress-bar"></div></div>'
        + '<div class="loading-status" id="loading-status">INITIALIZING PROTOCOLS...</div>'
        + '</div>';
      
      setContent(html);
      
      var msgIndex = 0;
      var interval = setInterval(function() {
        msgIndex++;
        var statusEl = document.getElementById('loading-status');
        if (statusEl && msgIndex < messages.length) {
          statusEl.textContent = messages[msgIndex];
        }
      }, 400);
      
      return interval;
    }

    // Views
    function mtShowView(view) {
      currentView = view;
      if (view === 'homepage') {
        setTabActive('home');
        currentSearchQuery = '';
        currentCategory = null;
        setActiveDirectory(null);
        toggleSidebar(true);
        mtLoadHomepage();
      } else if (view === 'playlists') {
        setTabActive('playlists');
        currentSearchQuery = '';
        currentCategory = null;
        setActiveDirectory(null);
        toggleSidebar(true);
        mtLoadPlaylists();
      }
    }

    async function mtLoadHomepage() {
      setStatus('SCANNING ARCHIVES...');
      setStatusText('Retrieving data fragments...');
      try {
        var terms = pickRandom(WEIRD_TERMS, 3);
        setStatusText('Querying: ' + terms[0].substring(0, 20) + '...');
        var results = await Promise.all(terms.map(function(t) { return ytSearch(t, 8); }));
        var seen = {};
        var all = [];
        results.forEach(function(r) {
          (r.items || []).forEach(function(v) {
            var id = v.videoId || v.id;
            if (id && !seen[id]) {
              seen[id] = true;
              all.push(v);
            }
          });
        });
        all.sort(function(a, b) { return (a.viewCount || 0) - (b.viewCount || 0); });
        
        totalResults = all;
        
        if (all.length === 0) {
          setContent('<div class="empty-state">No signals detected.<br>Initialize manual search.</div>');
          setStatusText('Archive empty');
          return;
        }
        
        var html = '<div class="section-title">⚠ FRAGMENTED SIGNALS DETECTED ⚠</div>';
        html += renderResultsPage(all, 1);
        setContent(html);
        setStatusText(all.length + ' fragments recovered');
        
        setTimeout(function() {
          document.querySelectorAll('.mt-video-title').forEach(function(el) {
            if (Math.random() > 0.7) {
              setTimeout(function() { triggerGlitch(el); }, Math.random() * 2000);
            }
          });
        }, 500);
      } catch(e) {
        setError(e.message);
      }
    }

    async function mtFilterByCategory(category, categoryName) {
      currentCategory = category;
      currentSearchQuery = '';
      setActiveDirectory(category);
      toggleSidebar(true);
      
      var terms = CATEGORY_TERMS[category] || WEIRD_TERMS;
      var selectedTerms = pickRandom(terms, 2);
      
      var loadingInterval = showLoadingAnimation();
      setStatusText('Decrypting category data...');
      
      try {
        var results = await Promise.all(selectedTerms.map(function(t) { return ytSearch(t, 15); }));
        clearInterval(loadingInterval);
        
        var seen = {};
        var all = [];
        results.forEach(function(r) {
          (r.items || []).forEach(function(v) {
            var id = v.videoId || v.id;
            if (id && !seen[id]) {
              seen[id] = true;
              all.push(v);
            }
          });
        });
        
        all.sort(function(a, b) { return (a.viewCount || 0) - (b.viewCount || 0); });
        totalResults = all;
        
        if (all.length === 0) {
          setContent('<div class="empty-state">No signals in category.<br>Archive corrupted.</div>');
          setStatusText('Category empty');
          return;
        }
        
        var html = '<div class="section-title">⚠ ' + categoryName.toUpperCase() + ' ARCHIVE ⚠</div>';
        html += renderResultsPage(all, 1);
        setContent(html);
        setStatusText(all.length + ' fragments in ' + categoryName);
      } catch(e) {
        clearInterval(loadingInterval);
        setError(e.message);
      }
    }

    function mtSearch(event) {
      event.preventDefault();
      var q = document.getElementById('mt-search-input').value.trim();
      if (!q) return;
      
      currentSearchQuery = q;
      currentCategory = null;
      setActiveDirectory(null);
      toggleSidebar(false);
      
      setTabActive('home');
      
      var loadingInterval = showLoadingAnimation();
      setStatusText('Executing search query...');
      
      ytSearch(q, 50).then(function(r) {
        clearInterval(loadingInterval);
        var items = r.items || [];
        totalResults = items;
        
        if (items.length === 0) {
          setContent('<div class="empty-state">No results for "' + q.replace(/</g, '&lt;') + '"<br>Signal lost in the void.</div>');
          setStatusText('Search failed');
          return;
        }
        
        var html = '<div class="section-title">QUERY RESULTS: ' + items.length + ' MATCHES</div>';
        html += renderResultsPage(items, 1);
        setContent(html);
        setStatusText('Scan complete: ' + items.length + ' matches');
      }).catch(function(e) { 
        clearInterval(loadingInterval);
        setError(e.message);
      });
    }

    async function mtLoadPlaylists() {
      setStatus('ACCESSING PLAYLIST DATABASE...');
      setStatusText('Connecting to storage...');
      try {
        var result = await rpc('list_playlists', {});
        var lists = result.playlists || [];
        var html = '<div class="section-title">⚠ DATA ARCHIVES ⚠</div>'
          + '<button class="mt-btn-new" onclick="mtCreatePlaylist()">+ Initialize New Archive</button>';
        if (lists.length === 0) {
          html += '<div class="empty-state">No archives found.<br>Create a new data container.</div>';
        } else {
          lists.forEach(function(pl) {
            playlistMap[pl.id] = pl;
            var name = (pl.name || 'Untitled').replace(/</g, '&lt;');
            var count = (pl.items || []).length;
            html += '<div class="mt-playlist-item" data-pl-id="' + escAttr(pl.id) + '" onclick="mtOpenPlaylistById(this.dataset.plId)">'
              + '<div class="mt-playlist-info">'
              + '<div class="mt-playlist-name">[ ' + name + ' ]</div>'
              + '<div class="mt-playlist-count">' + count + ' FRAGMENTS STORED</div></div>'
              + '<button class="mt-btn-delete" onclick="event.stopPropagation();mtDeletePlaylist(\'' + pl.id + '\')">PURGE</button>'
              + '</div>';
          });
        }
        setContent(html);
        setStatusText(lists.length + ' archives mounted');
      } catch(e) {
        setError(e.message);
      }
    }

    async function mtCreatePlaylist() {
      var name = window.prompt('Archive designation:');
      if (!name || !name.trim()) return;
      setStatusText('Initializing archive...');
      try {
        await rpc('save_playlist', { id: crypto.randomUUID(), name: name.trim(), items: [] });
        mtLoadPlaylists();
        setStatusText('Archive created');
      } catch(e) {
        alert('Archive initialization failed: ' + e.message);
        setStatusText('Creation failed');
      }
    }

    async function mtDeletePlaylist(id) {
      if (!window.confirm('Permanently purge this archive?')) return;
      setStatusText('Purging archive...');
      try {
        await rpc('delete_playlist', { id: id });
        mtLoadPlaylists();
        setStatusText('Archive purged');
      } catch(e) {
        alert('Purge failed: ' + e.message);
        setStatusText('Purge failed');
      }
    }

    function mtOpenPlaylist(pl) {
      currentPlaylist = pl;
      var name = (pl.name || 'Untitled').replace(/</g, '&lt;');
      var items = pl.items || [];
      var html = '<button class="mt-btn-back" onclick="mtShowView(\'playlists\')">← RETURN TO ARCHIVES</button>'
        + '<div class="section-title">ARCHIVE: [ ' + name + ' ]</div>';
      if (items.length === 0) {
        html += '<div class="empty-state">Empty archive.<br>Consume media to populate.</div>';
      } else {
        items.forEach(function(v) {
          var title = (v.title || v.id || 'Unknown').replace(/</g, '&lt;');
          html += '<div class="mt-track-item" data-vid-id="' + escAttr(v.id) + '" data-vid-title="' + escAttr(title) + '" onclick="mtWatchTrack(this)">'
            + '<span class="mt-track-title">▶ ' + title + '</span>'
            + '<button class="mt-btn-delete" onclick="event.stopPropagation();mtRemoveFromPlaylist(\'' + pl.id + '\',\'' + v.id + '\')">✕</button>'
            + '</div>';
        });
      }
      setContent(html);
      setStatusText(items.length + ' fragments in archive');
    }

    async function mtRemoveFromPlaylist(playlistId, videoId) {
      setStatusText('Modifying archive...');
      try {
        var result = await rpc('list_playlists', {});
        var lists = result.playlists || [];
        var pl = lists.find(function(p) { return p.id === playlistId; });
        if (!pl) return;
        pl.items = (pl.items || []).filter(function(v) { return v.id !== videoId; });
        await rpc('save_playlist', pl);
        currentPlaylist = pl;
        mtOpenPlaylist(pl);
        setStatusText('Fragment removed');
      } catch(e) {
        alert('Modification failed: ' + e.message);
        setStatusText('Operation failed');
      }
    }

    function mtWatchVideo(video) {
      currentVideo = video;
      var title = (video.title || video.id || 'Video').replace(/</g, '&lt;');
      
      // Generate weird random stats
      var corruptionLevel = Math.floor(Math.random() * 87 + 13);
      var signalStrength = Math.floor(Math.random() * 40 + 60);
      var distortion = (Math.random() * 15).toFixed(1);
      
      var html = '<div id="mt-watch">'
        + '<button class="back-btn" onclick="mtGoBackFromWatch()">← RETURN TO ARCHIVE</button>'
        + '<div id="mt-watch-frame-container">'
        + '<div class="corner-decoration corner-tl"></div>'
        + '<div class="corner-decoration corner-tr"></div>'
        + '<div class="corner-decoration corner-bl"></div>'
        + '<div class="corner-decoration corner-br"></div>'
        + '<div class="video-warning">⚠ LIVE FEED</div>'
        + '<div class="video-scanlines"></div>'
        + '<iframe id="mt-watch-frame" src="https://www.youtube-nocookie.com/embed/' + video.id + '?autoplay=1" allowfullscreen></iframe>'
        + '</div>'
        + '<div id="mt-watch-info">'
        + '<div id="mt-watch-title">> ' + title + '</div>'
        + '<div class="video-stats">'
        + '<div class="stat-item"><div class="stat-label">Signal Strength</div><div class="stat-value">' + signalStrength + '%</div></div>'
        + '<div class="stat-item"><div class="stat-label">Data Corruption</div><div class="stat-value">' + corruptionLevel + '%</div></div>'
        + '<div class="stat-item"><div class="stat-label">Distortion</div><div class="stat-value">' + distortion + 'dB</div></div>'
        + '<div class="stat-item"><div class="stat-label">Source</div><div class="stat-value">EXTERNAL</div></div>'
        + '</div>'
        + '<div id="mt-watch-actions">'
        + '<button class="action-btn primary" onclick="mtAddCurrentToPlaylist()">💀 STORE TO ARCHIVE</button>'
        + '<button class="action-btn" onclick="navigator.clipboard.writeText(\'https://youtube.com/watch?v=' + video.id + '\');alert(\'Link copied to clipboard\')">📋 COPY LINK</button>'
        + '</div></div>'
        + '<div class="glitch-decoration" style="top:20%;left:5%;">ERR_' + Math.floor(Math.random()*999) + '</div>'
        + '<div class="glitch-decoration" style="top:60%;right:8%;animation-delay:1s;">SIG_LOSS</div>'
        + '<div class="glitch-decoration" style="bottom:30%;left:10%;animation-delay:2s;">◈ DATA ◈</div>'
        + '</div>';
      
      setContent(html);
      setStatusText('SIGNAL ACQUIRED');
    }

    function mtGoBackFromWatch() {
      if (currentView === 'playlists' && currentPlaylist) {
        mtOpenPlaylist(currentPlaylist);
      } else {
        mtShowView(currentView === 'playlists' ? 'playlists' : 'homepage');
      }
    }

    async function mtAddCurrentToPlaylist() {
      if (!currentVideo) return;
      setStatusText('Processing...');
      try {
        var result = await rpc('list_playlists', {});
        var lists = result.playlists || [];
        if (lists.length === 0) {
          var createNew = window.confirm('No archives exist. Initialize new container?');
          if (!createNew) { setStatusText('Operation cancelled'); return; }
          var name = window.prompt('Archive designation:');
          if (!name || !name.trim()) { setStatusText('Operation cancelled'); return; }
          var newPl = { 
            id: crypto.randomUUID(), 
            name: name.trim(), 
            items: [{ id: currentVideo.id, title: currentVideo.title, link: 'https://www.youtube.com/watch?v=' + currentVideo.id, duration: 0 }] 
          };
          await rpc('save_playlist', newPl);
          alert('Fragment stored in "' + name.trim() + '"');
          setStatusText('Stored successfully');
          return;
        }
        var options = lists.map(function(pl, i) { return (i + 1) + '. ' + pl.name; }).join('\n');
        var choice = window.prompt('Select destination archive:\n' + options + '\n\nEnter number:');
        if (!choice) { setStatusText('Operation cancelled'); return; }
        var idx = parseInt(choice, 10) - 1;
        if (isNaN(idx) || idx < 0 || idx >= lists.length) { alert('Invalid selection.'); setStatusText('Invalid selection'); return; }
        var pl = lists[idx];
        pl.items = pl.items || [];
        pl.items.push({ id: currentVideo.id, title: currentVideo.title, link: 'https://www.youtube.com/watch?v=' + currentVideo.id, duration: 0 });
        await rpc('save_playlist', pl);
        alert('Fragment stored in "' + pl.name + '"');
        setStatusText('Stored successfully');
      } catch(e) {
        alert('Storage failed: ' + e.message);
        setStatusText('Storage failed');
      }
    }

    // Init
    function waitForSession(retries) {
      if (getSession()) {
        setStatusText('Connected');
        mtShowView('homepage');
        return;
      }
      if (retries <= 0) {
        setError('Authentication failed. Shell connection lost.');
        setStatusText('SYSTEM OFFLINE');
        return;
      }
      setTimeout(function() { waitForSession(retries - 1); }, 200);
    }

    waitForSession(25);
  </script>
</body>
</html>