---
import Layout from '../layouts/layout.astro';
import TopBar from '../components/desktop/TopBar.astro';
import Panel from '../components/desktop/Panel.astro';
import BootSequence from '../components/desktop/BootSequence.astro';
import FileManager from '../components/features/FileManager.astro';
import StyleManager from '../components/features/style/StyleManager.astro';
import ProcessMonitor from '../components/features/ProcessMonitor.astro';
import Emacs from '../components/features/Emacs.astro';
import Vim from '../components/features/Vim.astro';
import DesktopIcons from '../components/desktop/DesktopIcons.astro';
import Calendar from '../components/features/Calendar.astro';
import TerminalLab from '../components/features/TerminalLab.astro';
import AppManager from '../components/features/AppManager.astro';
import NetscapeNavigator from '../components/features/NetscapeNavigator.astro';
import Lynx from '../components/features/Lynx.astro';
import ManViewer from '../components/features/ManViewer.astro';
---

<Layout title="Time Capsule">
  <BootSequence />
  <div id="desktop-ui">
    <TopBar />
    <DesktopIcons />
    <TerminalLab />
    <FileManager />
    <Panel />
    <StyleManager />
    <Emacs />
    <Vim />
    <ProcessMonitor />
    <Calendar />
    <AppManager />
    <NetscapeNavigator />
    <Lynx />
    <ManViewer />
  </div>
</Layout>
