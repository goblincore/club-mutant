---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  date: Date
  description: string
  tags?: string[]
  version?: string
}

const { title, date, description, tags, version } = Astro.props
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---
<BaseLayout title={`${title} — Club Mutant`} description={description}>
  <article>
    <header style="margin-bottom: 2rem;">
      <h1 style="margin-bottom: 0.25rem;">{title}</h1>
      <div style="color: var(--text-muted); font-size: 0.85rem; display: flex; gap: 1rem; flex-wrap: wrap;">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {version && <span style="color: var(--accent);">v{version}</span>}
        {tags && tags.length > 0 && (
          <span>{tags.map(t => `#${t}`).join(' ')}</span>
        )}
      </div>
    </header>

    <slot />
  </article>

  <div style="margin-top: 3rem;">
    <a href="/">&larr; back to all posts</a>
  </div>
</BaseLayout>
